SUBMIT_DB_URL={{ submit_db_url }}
SUBMIT_NOMAD_ENDPOINT={{ submit_nomad_endpoint }}
SUBMIT_REPO_CONFIG={{ submit_repo_config_path }}
FEDCTL_SUBMIT_TOKENS={{ submit_tokens | join(',') }}
{% if submit_token_map is defined and submit_token_map %}
FEDCTL_SUBMIT_TOKEN_MAP={{ submit_token_map | to_json }}
{% endif %}
FEDCTL_SUBMIT_ALLOW_UNAUTH={{ submit_allow_unauth | lower }}
SUBMIT_DISPATCH_MODE={{ submit_dispatch_mode }}
SUBMIT_AUTOPURGE_COMPLETED_AFTER={{ submit_autopurge_completed_after_s }}
SUBMIT_UI_ENABLED={{ submit_ui_enabled | lower }}
SUBMIT_UI_SESSION_SECRET={{ submit_ui_session_secret }}
SUBMIT_UI_COOKIE_NAME={{ submit_ui_cookie_name }}
SUBMIT_UI_COOKIE_SECURE={{ submit_ui_cookie_secure | lower }}
