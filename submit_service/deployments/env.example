# SQLite DB location
SUBMIT_DB_URL=sqlite:///submit_service/state/submit.db

# Auth (comma-separated tokens). Empty tokens allow unauth access if allowed.
FEDCTL_SUBMIT_TOKENS=
FEDCTL_SUBMIT_ALLOW_UNAUTH=true

# Nomad config
SUBMIT_NOMAD_ENDPOINT=http://127.0.0.1:4646
SUBMIT_NOMAD_TOKEN=
SUBMIT_NOMAD_NAMESPACE=
SUBMIT_NOMAD_TLS_CA=
SUBMIT_NOMAD_TLS_SKIP_VERIFY=false
SUBMIT_NOMAD_INV_TTL=5
SUBMIT_AUTOPURGE_COMPLETED_AFTER=0

# Web UI
SUBMIT_UI_ENABLED=false
SUBMIT_UI_SESSION_SECRET=
SUBMIT_UI_COOKIE_NAME=fedctl_submit_session
SUBMIT_UI_COOKIE_SECURE=false

# Dispatcher
SUBMIT_DISPATCH_MODE=immediate
SUBMIT_DISPATCH_INTERVAL=10

# Job defaults
SUBMIT_DATACENTER=dc1
SUBMIT_DEFAULT_PRIORITY=50
SUBMIT_DOCKER_SOCKET=/var/run/docker.sock
