[Unit]
Description=Fedctl Submit Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/fedctl
EnvironmentFile=/etc/fedctl-submit.env
ExecStart=/opt/fedctl/.venv/bin/uvicorn submit_service.app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
